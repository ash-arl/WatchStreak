# ─── Local development ──────────────────────────────────────────────
# Copy this to apps/api/.env for running the backend outside Docker.

# App
APP_NAME=AI-Native Monorepo API
APP_VERSION=0.1.0
DEBUG=false

# Database
# Local SQLite (default for quick start):
DATABASE_URL=sqlite:///./dev.db
# Or point at the Docker Compose Postgres:
# DATABASE_URL=postgresql+psycopg2://monorepo:monorepo@localhost:5432/monorepo

# AI Memory (ChromaDB local vector DB — no API key needed)
MEMORY_DB_PATH=.data/chromadb

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# YouTube Data API v3 — get a key at https://console.cloud.google.com
YOUTUBE_API_KEY=

# CORS — comma-separated origins (Next.js dev servers)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
